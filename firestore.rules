rules_version = '2';

// Each signed-in user can read and write ONLY their own document subtree under
// /users/{uid}. Everything else is denied. This is what makes steps, program
// progress, workout history and in-progress session drafts persist server-side.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
