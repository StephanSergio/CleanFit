rules_version = '2';

// ============================================================
// SHARED Firestore rules — project `fitnessapp-92b38`
// ------------------------------------------------------------
// NOTE: this Firebase project is shared by TWO apps:
//   • CleanFit — requires login; per-user data under /users/{uid}.
//   • Mercato  — no login; a private family grocery list.
//
// One project = one rules file. Both repos contain exactly these
// rules so that publishing from one app never clobbers the other.
// If you change them, update BOTH repos
// (CleanFit/firestore.rules and mercato/firestore.rules) and publish.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── CleanFit — per user (requires login) ──
    // The recursive {document=**} wildcard covers steps, workouts,
    // programMeta, sessionDrafts, presets, etc.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Mercato — open (no login, private family app) ──
    match /ingredients/{doc}  { allow read, write: if true; }
    match /shoppingList/{doc} { allow read, write: if true; }
    match /categories/{doc}   { allow read, write: if true; }
    match /dishVotes/{doc}    { allow read, write: if true; }
    match /weekMenu/{doc}     { allow read, write: if true; }

    // Everything else stays locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
