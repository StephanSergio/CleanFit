VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — enables AI meal generation on the Meals page.
# Recommended: a proxy URL (key stays server-side). Since CleanFit shares the
# Firebase project with Mercato, point this at Mercato's deployed `recipe`
# function (which now supports a "meals" mode), e.g.:
#   https://us-central1-fitnessapp-92b38.cloudfunctions.net/recipe
VITE_CLAUDE_PROXY_URL=
# Simple alternative: a direct key (visible in the bundle — use a limited key).
VITE_ANTHROPIC_API_KEY=
